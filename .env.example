# HealthTrack API — environment template.
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored — NEVER commit real secrets. Placeholders only here.

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=production
# Long random string; rotate in production. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-string

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# DB_HOST is the compose service name ("db") when running the stack.
DB_HOST=db
DB_PORT=5432
DB_NAME=healthtrack
DB_USER=healthtrack
DB_PASSWORD=replace-with-a-strong-password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Anthropic API (used by the AI skill-review pipeline) ─────────────────────
# Placeholder only — supply the real key via GitHub secrets in CI, never here.
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key
